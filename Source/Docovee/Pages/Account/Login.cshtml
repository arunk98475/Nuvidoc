@page
@model Docovee.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = $"Sign In — {Branding.SiteName}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/docovee.css" asp-append-version="true" />
</head>
<body>
<nav>
    <partial name="Shared/_SiteLogo" />
    <div class="nav-right">
        <a href="/" class="nav-link">Home</a>
    </div>
</nav>

<div class="auth-page">
    <div class="auth-card">
        <h1>Sign in</h1>
        <p class="auth-subtitle">Access your patient or doctor profile.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label asp-for="Input.AccountType">I am a</label>
                <select asp-for="Input.AccountType" class="field-select">
                    <option value="Patient">Patient</option>
                    <option value="Doctor">Doctor</option>
                </select>
            </div>
            <div class="form-group">
                <label asp-for="Input.Username">Username</label>
                <input asp-for="Input.Username" class="field-input" autocomplete="username" />
            </div>
            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" class="field-input" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn-primary" style="width:100%;">Sign In</button>
            <p class="auth-footer-link">New here? <a href="/Account/Register">Register with @Branding.SiteName</a></p>
        </form>
    </div>
</div>
</body>
</html>
