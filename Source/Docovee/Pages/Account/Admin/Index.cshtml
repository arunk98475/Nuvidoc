@page
@model Docovee.Pages.Account.Admin.IndexModel
@{
    Layout = null;
    ViewData["Title"] = $"Admin Sign In — {Branding.SiteName}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="login-page">
    <div class="login-card">
        <h1>@Branding.SiteName Admin</h1>
        <p>Sign in to manage patients, doctors, and settings.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group" style="margin-bottom:14px;">
                <label asp-for="Input.Username">Username</label>
                <input asp-for="Input.Username" class="form-control" autocomplete="username" />
            </div>
            <div class="form-group" style="margin-bottom:20px;">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;">Sign In</button>
        </form>
    </div>
</body>
</html>
