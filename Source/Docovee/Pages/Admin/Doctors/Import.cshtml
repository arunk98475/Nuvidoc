@page
@model Docovee.Pages.Admin.Doctors.ImportModel
@{
    ViewData["Title"] = "Import Doctors";
}

<div class="admin-card">
    <h1>Import Doctors</h1>
    <p>Upload a CSV or Excel file. Doctor photos use the GMB Photo Link directly — no download during import.</p>

    <p class="hint">Expected columns: Location, Specialty, Practice Name, Doctor Name, Address, Office Phone Number, GMB Photo Link, Rating, Reviews, Summary of Reviews, Top 3 Procedures, Niche, Dental Implants, TMJ, Botox</p>

    <form id="import-form" enctype="multipart/form-data">
        <div class="form-group">
            <label>CSV or Excel file</label>
            <input type="file" id="import-file" name="file" accept=".csv,.xlsx,.xls" class="form-control" required />
        </div>
        <button type="submit" id="import-btn" class="btn btn-primary">Import</button>
        <a asp-page="Index" class="btn btn-secondary">Back</a>
    </form>

    <div id="import-progress-wrap" style="display:none;margin-top:20px;">
        <div class="import-progress-label">
            <span id="import-progress-text">Preparing import…</span>
            <span id="import-progress-pct">0%</span>
        </div>
        <div class="import-progress-track">
            <div id="import-progress-bar" class="import-progress-bar"></div>
        </div>
    </div>
</div>

<div id="import-results" class="admin-card" style="display:none;">
    <h2>Import Results</h2>
    <p id="import-summary"></p>
    <ul id="import-errors"></ul>
</div>

@section Scripts {
<script>
(function () {
    const form = document.getElementById("import-form");
    const fileInput = document.getElementById("import-file");
    const importBtn = document.getElementById("import-btn");
    const progressWrap = document.getElementById("import-progress-wrap");
    const progressBar = document.getElementById("import-progress-bar");
    const progressText = document.getElementById("import-progress-text");
    const progressPct = document.getElementById("import-progress-pct");
    const resultsCard = document.getElementById("import-results");
    const summaryEl = document.getElementById("import-summary");
    const errorsEl = document.getElementById("import-errors");

    form.addEventListener("submit", async function (e) {
        e.preventDefault();
        const file = fileInput.files[0];
        if (!file) return;

        importBtn.disabled = true;
        resultsCard.style.display = "none";
        errorsEl.innerHTML = "";
        progressWrap.style.display = "block";
        setProgress(0, "Uploading file…");

        try {
            const formData = new FormData();
            formData.append("file", file);

            const startRes = await fetch("/api/doctors/import", {
                method: "POST",
                body: formData,
                credentials: "same-origin"
            });

            if (!startRes.ok) {
                const err = await startRes.json().catch(() => ({}));
                throw new Error(err.message || "Import could not be started.");
            }

            const { jobId } = await startRes.json();
            setProgress(5, "Processing rows…");

            await pollUntilComplete(jobId);
        } catch (err) {
            showError(err.message || "Import failed.");
        } finally {
            importBtn.disabled = false;
        }
    });

    async function pollUntilComplete(jobId) {
        while (true) {
            const res = await fetch(`/api/doctors/import/${jobId}`, { credentials: "same-origin" });
            if (!res.ok) throw new Error("Lost connection to import job.");

            const status = await res.json();
            const pct = status.percent ?? 0;
            const label = status.complete
                ? "Import complete"
                : `Processing row ${status.processedRows} of ${status.totalRows}…`;
            setProgress(pct, label);

            if (status.complete) {
                showResults(status);
                return;
            }

            await new Promise(r => setTimeout(r, 400));
        }
    }

    function setProgress(pct, text) {
        progressBar.style.width = `${pct}%`;
        progressPct.textContent = `${pct}%`;
        progressText.textContent = text;
    }

    function showResults(status) {
        resultsCard.style.display = "block";
        if (status.errorMessage) {
            summaryEl.innerHTML = `<strong style="color:#c0392b;">${escapeHtml(status.errorMessage)}</strong>`;
            return;
        }
        summaryEl.innerHTML = `<strong>${status.imported}</strong> imported, <strong>${status.failed}</strong> failed.`;
        errorsEl.innerHTML = "";
        (status.errors || []).forEach(err => {
            const li = document.createElement("li");
            li.style.color = "#c0392b";
            li.textContent = err;
            errorsEl.appendChild(li);
        });
    }

    function showError(message) {
        progressWrap.style.display = "none";
        resultsCard.style.display = "block";
        summaryEl.innerHTML = `<strong style="color:#c0392b;">${escapeHtml(message)}</strong>`;
    }

    function escapeHtml(text) {
        const div = document.createElement("div");
        div.textContent = text;
        return div.innerHTML;
    }
})();
</script>
}
