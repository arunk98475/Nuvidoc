@page
@using Docovee.BLL.Data
@using System.Text.Json
@model IndexModel
@{
    Layout = null;
    ViewData["Title"] = $"{Branding.SiteName} — Find the Best Doctor Near Me";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="Find the best doctor near you. @Branding.SiteName matches you with top-rated local doctors based on your needs." />
    <link rel="stylesheet" href="~/css/docovee.css" asp-append-version="true" />
</head>
<body>

<nav>
    <div class="nav-left">
        <partial name="Shared/_SiteLogo" />
        <div class="nav-links">
            <a class="nav-link" href="#" onclick="scrollToChat(); return false;">Find a Doctor</a>
            <div class="nav-dropdown">
                <a class="nav-link" href="#">Specialties</a>
                <div class="nav-dropdown-menu">
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I need a dentist'); return false;">🦷 Dentist</a>
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I need a primary care doctor'); return false;">🩺 Primary Care</a>
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I have back pain'); return false;">🦴 Orthopedics</a>
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I have a skin rash'); return false;">🧴 Dermatology</a>
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I need a cardiologist'); return false;">❤️ Cardiology</a>
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I need a neurologist'); return false;">🧠 Neurology</a>
                    <a class="nav-dropdown-item" href="#" onclick="fillChatInput('I need a pediatrician'); return false;">👶 Pediatrics</a>
                    <a class="nav-dropdown-item" href="#" onclick="scrollToChat(); return false;">🌿 View all specialties →</a>
                </div>
            </div>
            <a class="nav-link" href="#how-it-works">How It Works</a>
            <a class="nav-link" href="#testimonials">Reviews</a>
        </div>
    </div>
    <div class="nav-right" id="nav-right" @(User.Identity?.IsAuthenticated == true ? "data-authenticated=\"true\"" : "")>
        @if (User.Identity?.IsAuthenticated == true)
        {
            if (User.IsInRole(AuthRoles.Admin))
            {
                <a href="/Admin/Patients" class="nav-link">Admin Panel</a>
            }
            else if (User.IsInRole(AuthRoles.Patient))
            {
                <a href="/Account/Profile" class="nav-link">My Profile</a>
            }
            else if (User.IsInRole(AuthRoles.Doctor))
            {
                <a href="/Account/DoctorProfile" class="nav-link">My Profile</a>
            }
            <a href="/Account/Logout" class="nav-link">Logout</a>
        }
        else
        {
            <a href="/Account/Login" class="nav-link">Login</a>
            <a href="/Account/Register/Doctor" class="nav-link nav-for-doctors">For Doctors</a>
        }
        <button class="nav-cta" onclick="window.scrollTo({top:0,behavior:'smooth'})">Find My Doctor</button>
    </div>
</nav>

<div class="hero-chat" id="hero-section">
    <div class="hero-left">
        <div class="hero-eyebrow">Find the Best Doctor Near Me · Book Online Today</div>
        <h1>Find a doctor<br>you can <em>trust.</em></h1>
        <p>Tell @Branding.ChatBotName what's going on. Your personal AI concierge finds the doctor who truly fits you — not just any doctor, the right one.</p>
    </div>

    <div class="hero-steps-strip">
        <div class="hero-step-cell">
            <div class="hero-step-label">Step 1</div>
            <div class="hero-step-text">Tell us what's wrong</div>
        </div>
        <div class="hero-step-cell">
            <div class="hero-step-label">Step 2</div>
            <div class="hero-step-text">We understand your needs</div>
        </div>
        <div class="hero-step-cell">
            <div class="hero-step-label">Step 3</div>
            <div class="hero-step-text">Get matched with top doctors</div>
        </div>
        <div class="hero-step-cell hero-step-cell-last">
            <div class="hero-step-label">Step 4</div>
            <div class="hero-step-text">Book instantly</div>
        </div>
    </div>

    <div class="hero-right" id="hero-chat-panel">
        <div class="chat-window">
            <div class="chat-header">
                <div class="ai-avatar">@Branding.ChatBotInitial</div>
                <div>
                    <div class="ai-name">@Branding.ChatBotName</div>
                    <div class="ai-status"><span class="ai-dot"></span>Here to help you find the right doctor</div>
                </div>
            </div>
            <div class="chat-messages" id="chat-messages">
                <div class="msg ai">
                        <div class="msg-avatar">@Branding.ChatBotName</div>
                    <div class="msg-bubble">
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(AuthRoles.Patient))
                        {
                            @:Hi @(Model.PatientFullName ?? User.Identity!.Name)! 👋 I'm @Branding.ChatBotName — your personal doctor-matching concierge. Welcome back! What's been going on? Tell me anything — a symptom, a concern, or just that you need a new doctor.
                        }
                        else
                        {
                            @:Hi! I'm @Branding.ChatBotName 👋 I'm here to personally match you with the right doctor — not just any doctor, the right one for YOU. What's going on? Tell me what's been on your mind health-wise, or what kind of doctor you're looking for.
                        }
                    </div>
                </div>
            </div>
            <div class="chips" id="quick-chips">
                <button class="chip" onclick="sendChip(this)">I need a dentist</button>
                <button class="chip" onclick="sendChip(this)">Tooth pain</button>
                <button class="chip" onclick="sendChip(this)">Dental implants</button>
                <button class="chip" onclick="sendChip(this)">Back pain</button>
                <button class="chip" onclick="sendChip(this)">Annual checkup</button>
                <button class="chip" onclick="sendChip(this)">Skin rash</button>
            </div>
            <div class="chat-input-area" id="chat-input-area">
                <textarea class="chat-input" id="chat-input" name="chat-message" rows="1" autocomplete="off" autocapitalize="sentences" spellcheck="true" placeholder="Tell @Branding.ChatBotName what's going on..." onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
                <button class="send-btn" id="send-btn" onclick="sendMessage()">
                    <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2v7z"/></svg>
                </button>
            </div>
        </div>
        <div class="disclaimer disclaimer-banner">⚠️ Not medical advice. For emergencies call 911.</div>
    </div>
</div>

<partial name="Shared/_HomeMarketing" />

<footer class="site-footer site-footer-rich">
    <div class="site-footer-inner">
        <div class="site-footer-brand">@Branding.SiteName.ToLowerInvariant().</div>
        <div class="site-footer-links">
            <a href="#">Terms of Use</a>
            <a href="#">Privacy Policy</a>
            <a href="#">Community Standards</a>
            <a href="#">Accessibility</a>
        </div>
        <div class="site-footer-copy">© @DateTime.UtcNow.Year @Branding.SiteName · Not medical advice · For emergencies call 911</div>
    </div>
</footer>

<script>
  window.nuvidocBranding = {
    siteName: "@Branding.SiteName",
    chatBotName: "@Branding.ChatBotName",
    matchSearchLoadingMessage: @Html.Raw(JsonSerializer.Serialize(NuviFlowContent.MatchSearchLoadingMessage))
  };
</script>
<script src="~/js/docovee.js" asp-append-version="true"></script>
</body>
</html>
